{
  "languages": {
    "Python": {
      "language_servers": ["ty", "ruff"],
      "format_on_save": "on",
    },
    "Markdown": {
      "format_on_save": "off",
      "remove_trailing_whitespace_on_save": false,
      "prettier": { "allowed": false },
    },
  },
  "lsp": {
    "ruff": {
      "initialization_options": {
        "settings": {
          "configuration": ".ruff.toml",
        },
      },
    },
  },
}
